
<% layout("/layouts/boilerplate") %>

<style>
    .filter-item:hover {
        opacity: 1 !important;
        cursor: pointer;
    }
    .tax-Info {
        display: none;
    }
</style>

<div class="container mt-3">

    <!-- FILTERS -->
    <div class="d-flex flex-wrap gap-3 align-items-center justify-content-center justify-content-md-start">

        <div class="text-center opacity-75 filter-item">
            <i class="fa-solid fa-fire"></i>
            <p class="mb-0 small">Trending</p>
        </div>

        <div class="text-center opacity-75 filter-item">
            <i class="fa-solid fa-bed"></i>
            <p class="mb-0 small">Rooms</p>
        </div>

        <div class="text-center opacity-75 filter-item">
            <i class="fa-solid fa-mountain-city"></i>
            <p class="mb-0 small">Amazing views</p>
        </div>

        <div class="text-center opacity-75 filter-item">
            <i class="fa-solid fa-city"></i>
            <p class="mb-0 small">Iconic cities</p>
        </div>

        <div class="text-center opacity-75 filter-item">
            <i class="fa-brands fa-fort-awesome"></i>
            <p class="mb-0 small">Castles</p>
        </div>

        <div class="text-center opacity-75 filter-item">
            <i class="fa-regular fa-snowflake"></i>
            <p class="mb-0 small">Arctic</p>
        </div>

        <div class="text-center opacity-75 filter-item">
            <i class="fa-solid fa-campground"></i>
            <p class="mb-0 small">Camping</p>
        </div>

        <div class="text-center opacity-75 filter-item">
            <i class="fa-solid fa-cow"></i>
            <p class="mb-0 small">Farms</p>
        </div>

        <div class="text-center opacity-75 filter-item">
            <i class="fa-solid fa-person-swimming"></i>
            <p class="mb-0 small">Pools</p>
        </div>

        <div class="text-center opacity-75 filter-item">
            <i class="fa-solid fa-igloo"></i>
            <p class="mb-0 small">Domes</p>
        </div>

        <div class="text-center opacity-75 filter-item">
            <i class="fa-solid fa-sailboat"></i>
            <p class="mb-0 small">Boat</p>
        </div>

        <!-- TAX TOGGLE -->
        <div class="border rounded-pill px-3 py-2 ms-md-auto mt-2 mt-md-0">
            <div class="form-check form-switch m-0">
                <input class="form-check-input" type="checkbox" id="switchCheckDefault">
                <label class="form-check-label small" for="switchCheckDefault">
                    Display Total after Taxes
                </label>
            </div>
        </div>

    </div>

    <!-- LISTINGS -->
    <div class="row g-4 mt-3">

        <% for(let listing of allListings){ %>

        <div class="col-12 col-sm-6 col-md-6 col-lg-4">
            <a class="listing-link text-decoration-none text-dark" href="/listings/<%= listing._id %>">

                <div class="card h-100 shadow-sm">

                    <img 
                        src="<%= listing.image.url %>" 
                        class="card-img-top img-fluid" 
                        style="height: 200px; object-fit: cover;" 
                        alt="listing_image"
                    >

                    <div class="card-body">
                        <p class="card-text mb-0">
                            <b><%= listing.title %></b><br>
                            ₹ <%= listing.price.toLocaleString("en-IN") %>/night
                            <span class="tax-Info"> +18% GST</span>
                        </p>
                    </div>

                </div>

            </a>
        </div>

        <% } %>

    </div>

</div>

<script>
    let TaxSwitch = document.getElementById("switchCheckDefault");

    TaxSwitch.addEventListener("click", () => {
        let taxInfo = document.querySelectorAll(".tax-Info");

        for (let info of taxInfo) {
            if (info.style.display === "inline") {
                info.style.display = "none";
            } else {
                info.style.display = "inline";
            }
        }
    });
</script>

