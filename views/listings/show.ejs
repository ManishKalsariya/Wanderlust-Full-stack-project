<% layout("/layouts/boilerplate") %>

<div class="row mt-3 mb-2">
    <div class="col-8 offset-2">
        <h3 class="offset-3"><b><%= listinggg.title %></b></h3>
    </div>

    <div class="card col-6 offset-3 show-card listing-card">
        <img src="<%= listinggg.image.url %>" class="card-img-top show-img" alt="listing-image">
        <div class="card-body">
            <p class="card-text"><i>Owned By : <%=listinggg.owner.username%></i></p>
            <p class="card-text"><%= listinggg.description %></p>
            <p class="card-text">&#8377; <%= listinggg.price.toLocaleString("en-IN") %></p>
            <p class="card-text"><%= listinggg.location %></p> 
            <p class="card-text"><%= listinggg.country %></p>
        </div>
    </div>

    <% if(currUser && listinggg.owner._id.toString() === currUser._id.toString()) { %>
        <div class="btns">
            <a class="btn btn-dark col-1 offset-3" href="/listings/<%= listinggg._id %>/edit">Edit</a>
            <form method="POST" action="/listings/<%=listinggg._id%>?_method=DELETE">
                <button class="btn btn-dark offset-5 edit-btn">Delete</button>
            </form>
        </div>
    <% } %>

    <div class="col-8 offset-3 mb-3">
        <hr>
        <% if(currUser) { %>
            <h4>Leave Review</h4>
            <form action="/listings/<%= listinggg._id %>/reviews" method="POST" novalidate class="needs-validation">
                <div class="mb-3 mt-3">
                    <label class="form-label" for="rating">Rating</label>
                    <fieldset class="starability-slot mb-1">
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="comments">Comments</label>
                    <textarea class="form-control" name="review[comment]" id="comments" cols="30" rows="10" required></textarea>
                    <div class="invalid-feedback">Please add some comments for review</div>
                </div>
                <button class="btn btn-outline-dark">Submit</button>
            </form>
            <hr>
        <% } %>
    </div>

    <% if(listinggg.reviews && listinggg.reviews.length > 0) { %>
        <p><b>All Reviews</b></p>
        <div class="row">
            <% for(review of listinggg.reviews) { %>
                <div class="card col-5 ms-3 mb-3">
                    <div class="card-body">
                        <h5 class="card-title">@<%= review.author.username %></h5>
                        <p class="starability-result card-text" data-rating="<%= review.rating %>"><%= review.rating %></p>
                        <p class="card-text"><%= review.comment %></p>
                    </div>
                    <form class="mb-3" action="/listings/<%= listinggg._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                        <button class="btn btn-sm btn-dark">Delete</button>
                    </form>
                </div>
            <% } %>
        </div>
    <% } %>

    <!-- MAP SECTION -->
    <div class="col-8 offset-3 mb-3">
        <h3>Where you'll be</h3>
        <div id="map" style="height: 500px; width: 100%;"></div>
    </div>
</div>

<!-- LEAFLET + MAPTILER SCRIPT -->
<script>
  // Safely pass coordinates, title, and location from server
  const coordinates = <%- JSON.stringify(listinggg.geometry.coordinates) %>;
  const title = "<%- listinggg.title.replace(/"/g, '&quot;') %>";
  const locationName = "<%- listinggg.location.replace(/"/g, '&quot;') %>";

  // Initialize the map centered at the listing location
  const map = L.map('map').setView([coordinates[1], coordinates[0]], 10);

  // Add MapTiler tiles using your working API key
  L.tileLayer('https://api.maptiler.com/maps/streets-v2/{z}/{x}/{y}.png?key=21pyEZsxAMnpEdwx4Lgd', {
    attribution: '&copy; <a href="https://www.maptiler.com/">MapTiler</a> &copy; <a href="https://www.openstreetmap.org/">OpenStreetMap</a> contributors'
  }).addTo(map);

  // Add a marker at the listing location
  L.marker([coordinates[1], coordinates[0]])
    .addTo(map)
    .bindPopup(`<b>${title}</b><br>${locationName}`)
    .openPopup();
</script>